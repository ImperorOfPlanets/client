# Язык интерфейса (ru) | 界面语言 (cn) | Interface language (en)
LANGUAGE=

# Администраторский логин и пароль | 管理员登录和密码 | Administrator login and password
ADMIN_LOGIN=
ADMIN_PASSWORD_HASH=

# Секретный ключ приложения | 应用程序密钥 | Application secret key
APP_SECRET_KEY=

# ID Проекта | 项目ID | Project ID
PROJECT_ID=

# SMTP настройки | SMTP设置 | SMTP settings
SMTP_HOST=                     # Адрес SMTP сервера | SMTP 服务器地址 | SMTP server address
SMTP_PORT=587                  # Порт SMTP сервера (обычно 25, 465, 587) | SMTP服务器端口（通常25，465，587）| SMTP server port (commonly 25, 465, 587)
SMTP_USER=                    # Пользователь для авторизации SMTP (если требуется) | SMTP 认证用户名（如需）| SMTP authentication username (if needed)
SMTP_PASSWORD=                # Пароль SMTP | SMTP密码 | SMTP password
SMTP_USE_TLS=true             # Использовать TLS для SMTP (true или false) | 是否启用TLS | Use TLS for SMTP (true or false)
SMTP_FROM_EMAIL=              # Email отправителя по умолчанию | 默认发件人邮箱 | Default sender email

# Адрес ядра для сверки регистрации и получения SMTP данных | 用于验证注册和获取SMTP数据的核心地址 | Core address for registration verification and SMTP data retrieval
CORE_SERVER_URL=https://core.myidon.site

# =============================================================================
# ПУТИ К DOCKER РЕСУРСАМ ПРОЕКТА | DOCKER PROJECT RESOURCE PATHS
# =============================================================================
# 
# PATH_APP_DOCKER - Корневая директория Docker-окружения проекта
# Содержит:
#   - Шаблоны docker-compose (генерация финального docker-compose.yml)
#   - Dockerfile's для сборки образов
#   - Скрипты запуска/остановки контейнеров
#   - Конфигурационные файлы и ресурсы для Docker
#
# PATH_APP_DOCKER_LOGS - Директория для логов Docker-контейнеров
# Хранит:
#   - Логи выполнения контейнеров
#   - Журналы работы приложений
#   - Файлы отладки Docker-окружения
#
# -----------------------------------------------------------------------------
# PATH_APP_DOCKER - Project's Docker environment root directory
# Contains:
#   - docker-compose templates (for final docker-compose.yml generation)
#   - Dockerfile's for image building
#   - Container startup/shutdown scripts
#   - Configuration files and resources for Docker
#
# PATH_APP_DOCKER_LOGS - Directory for Docker container logs
# Stores:
#   - Container execution logs
#   - Application operation journals
#   - Docker environment debug files
#
# =============================================================================
PATH_APP_DOCKER=/app/docker
PATH_APP_DOCKER_LOGS=/app/docker/logs
