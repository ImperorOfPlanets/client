#=========================== PROJECT VARIABLES ==========================#

# Имя проекта
PROJECTNAME=

# Имя окружения для Docker Compose
COMPOSE_PROJECT_NAME=

# Тип сервера CLIENT | AI | VOICE - НЕ РАБОТАЕТ
TYPE_SERVER=

# Дополнительно включаемые сервисы MARIADB,REVERB,WEBSSH,WEBSSHCLIENT,REDIS,TEI,TRANS,RUSTDESK
ENABLED_SERVICES=

# Основной домен приложения
DOMAIN=

# Пути
PATH_APP_DOCKER=/app/docker
PATH_APP_DOCKER_LOGS=/app/docker/logs
PATH_APP_STARTER=/app/starter
PATH_APP_PROJECT=/app/laravel
# Испольтзуеттся для DOCKER IN DOCKER
# PATH_VAR_RUN_DOCKER.SOCK=/var/run/docker.sock

#=========================== VPN SETTINGS ===============================#

# Необходимость подключения VPN
# Возможные значения: required | optional | disabled
VPN_REQUIRED=optional  

# Конфигурационный файл OpenVPN
VPN_CONFIG=./configs/vpn/config.ovpn

VPN_USERNAME=
VPN_PASSWORD=

#=========================== PHP CONFIGURATION ==========================#

# Максимальный размер загружаемых файлов
PHP_UPLOAD_MAX_FILESIZE=50M

# Максимальный размер POST-запросов
PHP_POST_MAX_SIZE=50M

# Управление режимом работы FastCGI Process Manager (FPM)
# Возможные значения: dynamic | static
PHP_FPM_PM=dynamic       

# Максимальное количество дочерних процессов FPM
PHP_FPM_MAX_CHILDREN=50

# Ограничение оперативной памяти на один процесс PHP
PHP_FPM_MEMORY_LIMIT=256M

#=========================== NGINX CONFIGURATION =======================#

# Максимальный размер тела HTTP-запроса
MAX_BODY_SIZE=100M

# Доменное имя веб-приложения
NGINX_DOMAIN=

#=========================== DATABASE SETTINGS ==========================#

# Путь к БД
DB_DATA_PATH=

# Тип используемого драйвера базы данных (mariadb|mysql|pgsql|sqlite)
DB_CONNECTION=mariadb

# Адрес сервера базы данных
DB_HOST=127.0.0.1

# Порт базы данных
DB_PORT=3306

# Имя базы данных
DB_DATABASE=

# Пользователь базы данных
DB_USERNAME=

# Пароль пользователя базы данных
DB_PASSWORD=

# Пароль администратора базы данных
DB_PASSWORD_ROOT=

#=========================== REDIS CONFIGURATION ========================#

# Путь данных REDIS
REDIS_DATA_PATH=./db/redis

# Хост Redis-сервера
REDIS_HOST=127.0.0.1

# Порт Redis-сервера
REDIS_PORT=6379

# Пароль Redis-сервера (null означает отсутствие пароля)
REDIS_PASSWORD=null


#=========================== LARAVEL APP SETTINGS ======================#

# Полный путь до каталога проекта Laravel
CLIENT_DATA_PATH=

# Окружение приложения (production|staging|local)
APP_ENV=local

# Включить отладочную информацию (true|false)
APP_DEBUG=true

# Базовый URL приложения
APP_URL=

#Язык по умолчанию!
APP_LOCALE=ru

# Метод кеширования данных (file|database|redis)
CACHE_STORE=database

# Используемый драйвер очереди задач (sync|database|redis)
QUEUE_CONNECTION=database

# URL REDIRECT (ГЕНЕРИРУЕТСЯ АВТОМАТИЧЕСКИЙ)
OAUTH_REDIRECT_URI=

# OAUTH ID получать через myidon.site
OAUTH_SECRET=

# OAUTH ID получать через myidon.site
OAUTH_CLIENT_ID=

# Qdrant Vector Database
QDRANT_HOST=http://qdrant:6333
QDRANT_COLLECTION=embeddings
QDRANT_TIMEOUT=30

# POLZA.AI Токен если выхолтите испольpовать

#=========================== LARAVEL REVERB ======================#

# ID приложения
REVERB_APP_ID=

# Ключ
REVERB_APP_KEY=

# ДеБАГ
REVERB_DEBUG=true

REVERB_APP_SECRET=

# ХОСТ (ИП ИЛИ ДОМЕН)
REVERB_HOST=

# Порт
REVERB_PORT=443

# SSL
REVERB_SCHEME=https

# Максимальный размер пакетов 1МБ
REVERB_APP_MAX_MESSAGE_SIZE=1048576

#=========================== QDRANT SETTINGS ======================#

QDRANT_DATA_PATH=./db/qdrant

#=========================== WEBSSH SETTINGS ======================#

# Путь до скрипта Webssh сервера
WEBSSH_DATA_PATH=

# Путь до скрипта Webssh клиента (web-интерфейс)
WEBSSHCLIENT_DATA_PATH=

# Домен
WEBSSH_DOMAIN=

WEBSSH_CONFIG_PATH=

#=========================== TEI - TEXT EMBEDDINGS INFERENCE  ======================#

# TEI Configuration
TEI_MODELS_PATH=./tei_models
TEI_MODEL_ID=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
HF_TOKEN=

# Available image tags:
# - For GPU (NVIDIA):
#   * "1.7"             (latest for Ampere/Ada Lovelace)
#   * "1.7-cuda12"      (CUDA 12 specific)
#   * "turing-1.7"      (for Turing GPUs: T4, RTX 20xx)
# - For CPU:
#   * "cpu-1.8.2"         (universal CPU image)
#   * "cpu-1.8.2-mkl"     (with Intel MKL optimization)

TEI_TAG=
TEI_PORT=8080
MAX_CONCURRENT_REQUESTS=10
MAX_BATCH_TOKENS=2048
POOLING=mean
TEI_DEVICE=cpu
# Параметры ресурсов для TEI
TEI_MEMORY_LIMIT=4G
TEI_CPUS_LIMIT=2

#=========================== LLM - TEXT GENERATION INFERENCE ======================#

LLM_MODELS_PATH=./llm_models
LLM_MODEL_ID=ai-forever/rugpt3small_based_on_gpt2
# Актуальный релиз TGI
LLM_TAG=3.3.6
# LLM_PORT=8081
LLM_DEVICE=gpu
LLM_MEMORY_LIMIT=4G
LLM_CPUS_LIMIT=4
LLM_MAX_INPUT_TOKENS=512
LLM_MAX_BATCH_PREFILL_TOKENS=512
LLM_MAX_TOTAL_TOKENS=1024
LLM_CUDA_LAUNCH_BLOCKING=1

#=========================== SentenceTransformer (TRANS) ======================#

TRANS_MODELS_PATH=./trans_models
TRANS_DEVICE=cpu                 # auto/cpu/gpu (управляет выбором Dockerfile)
UVICORN_WORKERS=auto
BATCH_SIZE=32
NORMALIZE_EMBEDDINGS=true
TRANS_MEMORY_LIMIT=8G
TRANS_CPUS_LIMIT=4

#=========================== ДЛЯ РАБОТЫ С ОБРАЗАМИ ======================#

USE_REGISTRY_IMAGES=false
PHP_IMAGE_TAG=0.1
OTHER_IMAGE_TAG=0.1

#=========================== VOSK MODELS ======================#

VOICE_CODE_PATH=./voice_code
VOICE_DATA_PATH=./voice_data
VOICE_DATA_SOUND_STORAGE=./voice_storage
# Путь к общей папке моделей VOSK
VOSK_MODELS_PATH=./vosk_models
# Список моделей VOSK (ключ = язык, значение = имя поддиректории с моделью)
VOSK_MODELS_LIST=ru:vosk-model-ru-0.42,en:vosk-model-en-us-0.42-gigaspeech,zh:vosk-model-cn-0.22

# Максимальный размер загружаемого аудио в МБ
MAX_AUDIO_FILESIZE_MB=50

# Форматы аудио, которые разрешено принимать (через POST)
ALLOWED_AUDIO_FORMATS=wav,mp3,ogg,m4a

# Добавляем новую переменную для энтропии
PYTHONHASHSEED=random

SPEECHBRAIN_MODELS_PATH=./speechbrain_models
SPEECHBRAIN_MODEL=speechbrain/lang-id-commonlanguage_ecapa

# TTS Service
TTS_CODE_PATH=./data/voice-tts/code
TTS_MODELS_PATH=./data/voice-tts/models
TTS_STORAGE_PATH=./data/voice-tts/storage
TTS_SERVICE_URL=http://voice-tts-${PROJECTNAME}:5001
TTS_SERVICE_URL=./voice_code
#=========================== RUSTDESK ======================#

# RustDesk Configuration
RUSTDESK_DATA_PATH=./data/rustdesk
RUSTDESK_DOMAIN=core.myidon.site
ALWAYS_USE_RELAY=Y  # Обязательно Y для работы через VPN!
ENCRYPTED_ONLY=Y

# Дополнительные опциональные переменные
# RUSTDESK_KEY=<ваш_ключ>  # Если хотите использовать свой ключ

#=========================== BROWSER ======================#

BROWSER_CODE_PATH=/path/to/browser/code
BROWSER_DATA_PATH=/path/to/browser/data

#=========================== SLAM ======================#

# Для orb-slam3-server
SLAM_CODE_PATH=./apps/orb_slam3
SLAM_MODELS_PATH=./data/slam/models
SLAM_DATA_PATH=./data/slam/data
SLAM_MAPS_PATH=./data/slam/maps

# Для yolo-detector-server  
YOLO_CODE_PATH=./apps/yolo_detector
YOLO_MODELS_PATH=./data/yolo/models
YOLO_DATA_PATH=./data/yolo/data

# Для slam-api-server
SLAM_API_CODE_PATH=./apps/slam_api
SLAM_API_DATA_PATH=./data/slam_api/data

#=========================== N8N ======================#

# N8N Configuration
N8N_USER=admin
N8N_PASSWORD=your_secure_password_here
N8N_ENCRYPTION_KEY=your_32_character_encryption_key_here
N8N_DB_NAME=n8n  # Название БД для N8N (отдельная от основного приложения)

# Пути для данных N8N
N8N_DATA_PATH=./data/n8n
N8N_WORKFLOWS_PATH=./data/n8n/workflows