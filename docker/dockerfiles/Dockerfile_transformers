# syntax=docker/dockerfile:1.4
ARG DEVICE=cpu

# ================== Базовые образы ================== #
FROM python:3.11-slim-bookworm AS base-cpu
FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04 AS base-gpu

# ================== Stage: builder ================== #
FROM base-${DEVICE} AS builder
WORKDIR /app

# Системные пакеты
RUN apt-get update && apt-get install -y --no-install-recommends \
    g++ make git curl python3 python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Python зависимости
RUN if [ "$DEVICE" = "cpu" ]; then \
      pip install --no-cache-dir --prefix=/install \
        torch==2.1.2+cpu -f https://download.pytorch.org/whl/cpu/torch_stable.html; \
    else \
      pip install --no-cache-dir --prefix=/install torch==2.1.2; \
    fi && \
    pip install --no-cache-dir --prefix=/install \
      sentence-transformers==2.6.1 \
      fastapi==0.109.1 \
      "uvicorn[standard]"==0.27.0 \
      numpy==1.26.3 \
      huggingface-hub==0.20.3 \
      transformers==4.37.2 \
      requests==2.31.0 \
      tqdm==4.66.1

# ================== Stage: runtime ================== #
FROM base-${DEVICE} AS runtime
WORKDIR /app

# Копирование зависимостей
COPY --from=builder /install /usr/local

# Логи
RUN mkdir -p /var/log/transformers && chmod 777 /var/log/transformers

# Оптимизация
ENV OMP_NUM_THREADS=1
ENV TOKENIZERS_PARALLELISM=false

EXPOSE 5000

# Копировать приложение внутрь образа, если есть папка app
# COPY ./app /app

CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "5000", "--workers", "1"]
