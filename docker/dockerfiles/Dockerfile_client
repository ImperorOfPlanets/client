# ================================
# Minimal PHP 8.3 image for Laravel
# ================================
FROM php:8.3-fpm

# Working directory
WORKDIR /

# ================================
# 1. System packages
# ================================
RUN apt-get update && apt-get install -y \
    mariadb-client \
    curl \
    unzip \
    git \
    libfreetype6-dev \
    libjpeg62-turbo-dev \
    libpng-dev \
    libwebp-dev \
    libssh2-1-dev \
    && rm -rf /var/lib/apt/lists/*

# ================================
# 2. PHP extensions for Laravel
# ================================
RUN docker-php-ext-configure gd \
    --with-freetype \
    --with-jpeg \
    --with-webp \
    && docker-php-ext-install -j$(nproc) \
    pdo \
    pcntl \
    pdo_mysql \
    gd \
    && pecl install \
    ssh2-1.3.1 \
    redis \
    && docker-php-ext-enable \
    ssh2 \
    redis

# ================================
# 3. Install Composer
# ================================
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# ================================
# 4. Install Node.js and NPM
# ================================
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# ================================
# 5. Create dist folder with Laravel
# ================================
RUN mkdir -p /var/www/html.dist && \
    echo "Installing fresh Laravel to /var/www/html.dist..." && \
    cd /var/www/html.dist && \
    composer create-project laravel/laravel . --prefer-dist --no-interaction --no-dev && \
    echo "Laravel ready in /var/www/html.dist"

# ================================
# 6. Copy init script
# ================================
COPY configs/init/client-init.sh /usr/local/bin/client-init.sh
RUN chmod +x /usr/local/bin/client-init.sh

# ================================
# 7. Setup working user
# ================================
RUN groupadd -g 1000 appuser \
    && useradd -u 1000 -ms /bin/bash -g appuser appuser

# ================================
# 8. Final working directory
# ================================
WORKDIR /var/www/html

# ================================
# 9. Entrypoint
# ================================
ENTRYPOINT ["client-init.sh"]
CMD ["php-fpm"]