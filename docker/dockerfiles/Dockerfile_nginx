FROM nginx:alpine

# ================================
# 1️⃣ Копируем скрипт entrypoint и считаем хэш
# ================================
COPY configs/init/nginx-docker-entrypoint.sh /docker-entrypoint.d/
RUN set -e; \
    HASH=$(sha256sum /docker-entrypoint.d/nginx-docker-entrypoint.sh | cut -d' ' -f1); \
    echo "NGINX_ENTRYPOINT_HASH=$HASH"; \
    chmod +x /docker-entrypoint.d/nginx-docker-entrypoint.sh

# ================================
# 2️⃣ Копируем шаблоны конфигурации и считаем хэш
# ================================
COPY configs/nginx/confs/templates /etc/nginx/templates
RUN set -e; \
    HASH=$(find /etc/nginx/templates -type f -exec sha256sum {} \; | sha256sum | cut -d' ' -f1); \
    echo "NGINX_TEMPLATES_HASH=$HASH"

# ================================
# 3️⃣ Копируем сертификаты (если нужны) и считаем хэш
# ================================
COPY configs/nginx/certs /etc/nginx/certs
RUN set -e; \
    HASH=$(find /etc/nginx/certs -type f -exec sha256sum {} \; | sha256sum | cut -d' ' -f1); \
    echo "NGINX_CERTS_HASH=$HASH"

# ================================
# 4️⃣ Стандартная команда nginx
# ================================
CMD ["nginx", "-g", "daemon off;"]
