# syntax=docker/dockerfile:1.4
ARG DEVICE=cpu

# ================== Базовые образы ================== #
FROM python:3.11-slim-bookworm AS base-cpu

FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04 AS base-gpu

# ================== Stage: system-deps ================== #
FROM base-${DEVICE} AS system-deps
WORKDIR /app

# Устанавливаем системные пакеты
RUN apt-get update && apt-get install -y --no-install-recommends \
    g++ make git curl python3 python3-pip ffmpeg libsndfile1 \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# ================== Stage: builder ================== #
FROM system-deps AS builder
WORKDIR /app

# Копируем requirements.txt для лучшего кэширования
COPY configs/voice/requirements.txt .

# Python зависимости - устанавливаем в систему, а не в /install
RUN pip install --no-cache-dir -r requirements.txt

# ================== Stage: runtime ================== #
FROM base-${DEVICE} AS runtime
WORKDIR /app

# Только необходимые системные зависимости для рантайма
RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg libsndfile1 \
    && rm -rf /var/lib/apt/lists/* \
    && apt-get clean

# Копирование зависимостей Python из builder
COPY --from=builder /usr/local /usr/local

# Создаем нужные директории
RUN mkdir -p /app/code /app/storage/sounds /app/temp /var/log/voice && \
    chmod 777 /app/storage/sounds /app/temp /var/log/voice

# Оптимизация
ENV OMP_NUM_THREADS=1
ENV TOKENIZERS_PARALLELISM=false
ENV PYTHONPATH=/app/code

EXPOSE 5000

# Код монтируется через volumes в docker-compose