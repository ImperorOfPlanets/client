FROM alpine:3.18

# ================================
# 1️⃣ Установка OpenVPN и необходимых утилит
# ================================
RUN apk add --no-cache \
    openvpn \
    iproute2 \
    curl \
    iputils \
    iptables \
    bash \
    nodejs \
    npm

# ================================
# 3️⃣ Настройка рабочей директории
# ================================
WORKDIR /app