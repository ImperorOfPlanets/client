FROM ubuntu:20.04

WORKDIR /app

# Установка системных зависимостей
RUN apt-get update && apt-get install -y \
    python3-pip \
    cmake \
    git \
    libopencv-dev \
    libeigen3-dev \
    libboost-all-dev \
    libgl1-mesa-dev \
    libglew-dev \
    libpython3.8-dev \
    wget \
    && rm -rf /var/lib/apt/lists/*

# Установка Python зависимостей
RUN pip3 install \
    numpy \
    opencv-python \
    open3d \
    pyquaternion \
    fastapi \
    uvicorn \
    pillow

# Клонирование ORB-SLAM3
RUN git clone https://github.com/UZ-SLAMLab/ORB_SLAM3.git ORB_SLAM3 \
    && cd ORB_SLAM3 \
    && chmod +x build.sh \
    && ./build.sh

# Создание структуры папок
RUN mkdir -p /app/code /app/models /app/data /app/maps

# Копирование кода
COPY apps/orb_slam3/ /app/code/

# Vocabulary файл
RUN wget -O /app/models/ORBvoc.txt https://github.com/raulmur/ORB_SLAM3/raw/master/Vocabulary/ORBvoc.txt

CMD ["python3", "/app/code/slam_server.py"]