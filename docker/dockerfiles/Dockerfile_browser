FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

# Установка системных зависимостей для Playwright и браузеров
RUN apt-get update && apt-get install -y \
    ca-certificates \
    fonts-liberation \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdrm2 \
    libgbm1 \
    libnspr4 \
    libnss3 \
    libx11-xcb1 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    libxrender1 \
    libxss1 \
    libxtst6 \
    lsb-release \
    xdg-utils \
    wget \
    libasound2 \
    libatspi2.0-0 \
    libdbus-1-3 \
    libxcb1 \
    libxkbcommon0 \
    libx11-6 \
    libxext6 \
    libxfixes3 \
    libpango-1.0-0 \
    libcairo2 \
    && rm -rf /var/lib/apt/lists/*

# Копируем requirements.txt и устанавливаем Python зависимости с подсчётом хеша для кеширования
COPY configs/browser/requirements.txt /app/requirements.txt
RUN set -e; \
    HASH=$(sha256sum /app/requirements.txt | cut -d' ' -f1); \
    echo "REQUIREMENTS_HASH=$HASH"; \
    pip install --no-cache-dir -r /app/requirements.txt

# Устанавливаем браузеры Playwright через Python модуль (только после pip install)
RUN python -m playwright install
